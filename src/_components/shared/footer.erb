<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__intro">
      <h2><%= @metadata.title %></h2>
      <p><%= @metadata.description %></p>
    </div>

    <div class="site-footer__columns">
      <% @navigation.each_value do |group| %>
        <section>
          <h3><%= group.fetch("title") %></h3>
          <ul>
            <% group.fetch("links").each do |link| %>
              <% external = link.fetch("url").start_with?("http://", "https://") %>
              <li>
                <a href="<%= link.fetch("url") %>" <%= 'target="_blank" rel="noopener"' if external %>>
                  <%= link.fetch("title") %>
                </a>
              </li>
            <% end %>
          </ul>
        </section>
      <% end %>
    </div>
  </div>
</footer>
